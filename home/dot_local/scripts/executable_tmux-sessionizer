#!/usr/bin/env bash
#
# original script from: https://github.com/ThePrimeagen/.dotfiles

if [[ $# -eq 1 ]]; then
	selected=$1
else
	dirstring=$(cat $HOME/.local/scripts/.tmux-directories)
	_dirs=($dirstring)
	existing=()
	for i in ${_dirs[@]}; do
		path=${i/#\~/$HOME}
		if [ -d $path ]; then
			existing+=($path)
		fi
	done
	# https://thevaluable.dev/practical-guide-fzf-example/
	if command -v fd &>/dev/null; then
		selected=$(fd . -p -H -L -d 1 -t d ${existing[@]} | fzf --layout reverse --multi --margin=30%,20%,30%,20% --info=inline --prompt="箚펶 " --pointer="箚퀫" --border=rounded)	
	else
		selected=$(find -L ${existing[@]} -mindepth 1 -maxdepth 1 -type d | fzf --layout reverse --multi --margin=30%,20%,30%,20% --info=inline --prompt="箚펶 " --pointer="箚퀫" --border=rounded)
	fi
fi

if [[ -z $selected ]]; then
	exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)


if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
	tmux new-session -s $selected_name -c $selected
	exit 0
fi

if ! tmux has-session -t=$selected_name 2>/dev/null; then
	tmux new-session -ds $selected_name -c $selected
fi

if [[ -z $TMUX ]]; then
	tmux attach -t $selected_name
else
	tmux switch-client -t $selected_name
fi
