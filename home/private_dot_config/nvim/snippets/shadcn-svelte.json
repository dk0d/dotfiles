{
  "Shadcn Tabs": {
    "scope": "svelte",
    "prefix": "shadTabs",
    "description": "Shadcn-Svelte Tabs",
    "body": [
      "<Tabs.Root>",
      "<Tabs.List>",
      "\t<Tabs.Trigger value=\"$1\">Tab1</Tabs.Trigger>",
      "\t<Tabs.Trigger value=\"tab2\">Tab2</Tabs.Trigger>",
      "</Tabs.List>",
      "\t<Tabs.Content value=\"$1\">Tab 1 Yea</Tabs.Content>",
      "\t<Tabs.Content value=\"tab2\">Tab 2 Yea</Tabs.Content>",
      "</Tabs.Root>"
    ]
  },
  "Shadcn Card": {
    "scope": "svelte",
    "prefix": "shadCard",
    "description": "Shadcn-Svelte-Card",
    "body": [
      "<Card.Root>",
      "<Card.Header>",
      "<Card.Title>CardTitle</Card.Title>",
      "<Card.Description>CardDescription</Card.Description>",
      "</Card.Header>",
      "<Card.Content>",
      "$1",
      "</Card.Content>",
      "<Card.Footer>",
      "<Button variant=\"outline\">Cancel</Button>",
      "<Button>Deploy</Button>",
      "</Card.Footer>",
      "</Card.Root>"
    ]
  }
}
